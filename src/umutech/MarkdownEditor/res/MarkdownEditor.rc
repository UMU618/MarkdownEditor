    GROUPBOX        "",IDC_STATIC,7,7,133,66
    ICON            IDR_MAINFRAME,IDC_STATIC,64,18,20,20
    CTEXT           "MarkdownEditor (GFM)",IDC_VERSION,16,40,114,14
    CTEXT           "(c) Copyright UMUTech 2026",IDC_STATIC,16,56,114,14
    LTEXT           "HTML Renderer: MSHTML",IDC_HTML_RENDERER,7,77,133,8
END

IDD_DOCUMENTS DIALOGEX 0, 0, 342, 195
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CLIPCHILDREN | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Windows"
FONT 8, "MS Shell Dlg", 0, 0, 0x0
BEGIN
    LISTBOX         IDC_LIST,7,7,255,181,LBS_NOINTEGRALHEIGHT | LBS_EXTENDEDSEL | WS_VSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "&Activate",IDOK,267,7,68,14
    PUSHBUTTON      "&Close Window(s)",IDCLOSE,267,26,68,14
END


